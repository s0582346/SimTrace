flowchart TB
    USER["User<br>Problem in, result out"]:::user

    subgraph SYSTEM["Agent System — LangGraph"]
        direction TB

        SUP["Supervisor"]:::supervisor

        subgraph SPECIALISTS["Specialist agents"]
            direction LR
            MOD["Modeler"]:::agent
            VER["Verifier"]:::vv
            SIM_A["Simulator"]:::agent
            ANA["Analyst"]:::agent
        end
    end

    subgraph TOOLS["tools"]
        direction LR
        T_MOD["get_schema_help<br>load_template<br>emit_des_json"]:::tool
        T_VER["validate_schema<br>check_consistency<br>compare_kpis"]:::tool
        T_SIM["simulate_des<br>run_replications<br>export_results"]:::tool
        T_ANA["summarize_runs<br>compare_vs_expected"]:::tool
    end

    USER -->|problem description| SUP
    SUP -->|final result| USER
    SUP -. clarify if ambiguous .-> USER

    SUP -->|invoke| MOD
    SUP -->|invoke| VER
    SUP -->|invoke| SIM_A
    SUP -->|invoke| ANA

    MOD -.-> T_MOD
    VER -.-> T_VER
    SIM_A -.-> T_SIM
    ANA -.-> T_ANA

    classDef user fill:#1E3A5F,stroke:#0D1F33,color:#fff,stroke-width:2px
    classDef supervisor fill:#5B2C6F,stroke:#2E1438,color:#fff,stroke-width:2px
    classDef agent fill:#0E6655,stroke:#06332A,color:#fff,stroke-width:2px
    classDef vv fill:#922B21,stroke:#4A1610,color:#fff,stroke-width:2px
    classDef tool fill:#196F3D,stroke:#0B3A20,color:#fff,stroke-width:2px