# simgen environment variables
#
# Copy to .env and fill in. NOTE: nothing loads .env automatically yet — these
# are documented for when the agent/client code lands. The OpenTelemetry SDK,
# however, does read OTEL_* from the process environment.

# Claude API key — used by the agent/client side (not yet wired up).
ANTHROPIC_API_KEY=your_key_here
