{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://text2sim.com/schemas/des-simpy-production-model-v2.json",
  "title": "SimPy-Compatible Production/Manufacturing DES Model Configuration (v2)",
  "description": "Practical DES configuration for production and manufacturing systems, optimized for SimPy's native capabilities. Implementation notes: (1) exp(x) uses mean=x, (2) max_wait balking is implemented as a reneging timeout, (3) entity_type probabilities must sum to 1.0, (4) smaller priority numbers = higher priority (e.g. expedited entities), (5) buffer capacities enforce upstream blocking when full, (6) setup_time applies once at workstation entry; sequence-dependent setups use 'changeover_matrix' on the workstation (only one of the two is active when both are present, with changeover_matrix taking precedence on family change), (7) scrap removes the entity from the line; rework loops it back to a specified step, (8) parallel_activities forks one entity across multiple branches and rejoins it (the entity keeps its identity), (9) assembly_rules combine multiple entities into one (BOM-style), (10) statistics support per-station and per-entity-type breakdowns; legacy boolean form is still accepted for backwards compatibility.",
  "type": "object",
  "required": ["run_time"],
  "oneOf": [
    {"required": ["arrival_pattern"], "not": {"required": ["num_entities"]}},
    {"required": ["num_entities"], "not": {"required": ["arrival_pattern"]}}
  ],
  "properties": {
    "run_time": {
      "type": "number",
      "description": "Total simulation runtime (in time units, e.g. minutes of a shift)",
      "minimum": 0.1,
      "examples": [480, 960, 1440, 7200]
    },
    "num_entities": {
      "type": "integer",
      "description": "Total number of entities to generate (mutually exclusive with arrival_pattern). Useful for closed-system runs.",
      "minimum": 1,
      "examples": [100, 500, 1000]
    },
    "time_unit": {
      "type": "string",
      "enum": ["seconds", "minutes", "hours", "days"],
      "default": "minutes",
      "description": "Unit of time for all durations in the model (documentation only — values are unitless to SimPy)"
    },
    "entity_types": {
      "type": "object",
      "description": "Different entity types with their characteristics (product mix)",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["probability"],
          "properties": {
            "probability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Mix probability for this entity type (must sum to 1.0 across all types that are released from the arrival_pattern; types only produced by assembly_rules may use probability 0)"
            },
            "value": {
              "type": "object",
              "description": "Per-unit value range (e.g. revenue, contribution margin, or cost)",
              "properties": {
                "min": {"type": "number", "minimum": 0},
                "max": {"type": "number", "minimum": 0}
              },
              "required": ["min", "max"]
            },
            "priority": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 5,
              "description": "Entity priority (1=highest/expedited, 10=lowest). Used by priority/preemptive workstations and routing rules."
            },
            "process_plan": {
              "type": "string",
              "description": "Name of the process_plans entry this entity type follows. If omitted, processing_rules.steps is used."
            },
            "batch_size": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Number of units per released entity (lot size). Affects per-step service time when batching is enabled."
            },
            "attributes": {
              "type": "object",
              "description": "Custom attributes for routing, setup grouping, or quality rules (e.g. material, family, color)",
              "patternProperties": {
                "^[a-zA-Z][a-zA-Z0-9_]*$": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "number"},
                    {"type": "boolean"}
                  ]
                }
              }
            }
          },
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "standard_part": {"probability": 0.7, "value": {"min": 50, "max": 80}, "priority": 5, "batch_size": 10, "attributes": {"family": "A"}},
          "premium_part": {"probability": 0.25, "value": {"min": 150, "max": 250}, "priority": 3, "batch_size": 5, "attributes": {"family": "B"}},
          "hot_job": {"probability": 0.05, "value": {"min": 500, "max": 1000}, "priority": 1, "batch_size": 1, "attributes": {"family": "B"}}
        }
      ]
    },
    "workstations": {
      "type": "object",
      "description": "Production resources: machines, cells, operators, or workstations (maps directly to SimPy resource types)",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["capacity"],
          "properties": {
            "capacity": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of parallel servers (e.g. identical machines in the cell)"
            },
            "resource_type": {
              "enum": ["fifo", "priority", "preemptive"],
              "default": "fifo",
              "description": "Queue discipline: fifo=Resource, priority=PriorityResource, preemptive=PreemptiveResource (preemption used for expedited-entity interruption)"
            },
            "setup_time": {
              "type": "string",
              "pattern": "^(uniform|normal|gauss|exp)\\s*\\(\\s*[0-9.]+\\s*(,\\s*[0-9.]+\\s*)?\\)$",
              "description": "Sequence-independent setup time applied once per entity arrival at this workstation. Superseded by changeover_matrix when a family change is detected."
            },
            "changeover_matrix": {
              "type": "object",
              "description": "Sequence-dependent setup times keyed by 'FromFamily>ToFamily' (the 'family' attribute on entity_types). The matrix is consulted on every entity arrival; if the previous entity's family differs from the current entity's, the matching duration is applied. Keys with identical from/to (e.g. 'A>A') may be set to zero or omitted (omitted = no setup).",
              "patternProperties": {
                "^[a-zA-Z0-9_]+>[a-zA-Z0-9_]+$": {
                  "type": "string",
                  "pattern": "^(uniform|normal|gauss|exp)\\s*\\(\\s*[0-9.]+\\s*(,\\s*[0-9.]+\\s*)?\\)$"
                }
              },
              "additionalProperties": false
            },
            "batch_processing": {
              "type": "object",
              "description": "If present, the workstation processes entities in batches",
              "properties": {
                "min_batch": {"type": "integer", "minimum": 1},
                "max_batch": {"type": "integer", "minimum": 1},
                "wait_for_full": {"type": "boolean", "default": false, "description": "If true, wait for max_batch before starting; otherwise start when min_batch is reached"}
              },
              "required": ["min_batch", "max_batch"]
            }
          },
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "cnc_mill": {"capacity": 2, "resource_type": "priority", "setup_time": "normal(15, 3)"},
          "heat_treat": {"capacity": 1, "resource_type": "fifo", "batch_processing": {"min_batch": 4, "max_batch": 8, "wait_for_full": false}},
          "assembly": {"capacity": 3, "resource_type": "preemptive", "changeover_matrix": {"A>B": "uniform(10, 20)", "B>A": "uniform(10, 20)"}},
          "inspection": {"capacity": 1, "resource_type": "fifo"}
        }
      ]
    },
    "buffers": {
      "type": "object",
      "description": "Inter-stage WIP buffers with finite capacity. When full, upstream workstations block (stall) — this is the production analog of balking.",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["capacity", "upstream", "downstream"],
          "properties": {
            "capacity": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum WIP units the buffer can hold"
            },
            "upstream": {
              "type": "string",
              "description": "Workstation that pushes into this buffer (blocks when buffer is full)"
            },
            "downstream": {
              "type": "string",
              "description": "Workstation that pulls from this buffer (starves when buffer is empty)"
            },
            "initial_level": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Initial WIP in buffer at sim start"
            }
          },
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "wip_mill_to_assembly": {"capacity": 20, "upstream": "cnc_mill", "downstream": "assembly", "initial_level": 0}
        }
      ]
    },
    "processing_rules": {
      "type": "object",
      "description": "Default linear process flow and service times. Job types with their own 'process_plan' override this. All step names must match workstation names.",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1,
          "description": "Ordered list of workstations on the default routing"
        }
      },
      "patternProperties": {
        "^(?!steps$)[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "properties": {
            "distribution": {
              "type": "string",
              "pattern": "^(uniform|normal|gauss|exp)\\s*\\(\\s*[0-9.]+\\s*(,\\s*[0-9.]+\\s*)?\\)$",
              "description": "Per-unit processing (cycle) time distribution"
            },
            "conditional_distributions": {
              "type": "object",
              "description": "Per-entity-type processing times (overrides 'distribution')",
              "patternProperties": {
                "^[a-zA-Z][a-zA-Z0-9_]*$": {
                  "type": "string",
                  "pattern": "^(uniform|normal|gauss|exp)\\s*\\(\\s*[0-9.]+\\s*(,\\s*[0-9.]+\\s*)?\\)$"
                }
              }
            },
            "scale_by_batch": {
              "type": "boolean",
              "default": true,
              "description": "If true, total step time = distribution_sample * batch_size; if false, time is per-entity regardless of batch size."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "steps": ["cnc_mill", "assembly", "inspection"],
          "cnc_mill": {"distribution": "normal(8, 1.5)", "scale_by_batch": true},
          "assembly": {
            "conditional_distributions": {
              "standard_part": "normal(5, 1)",
              "premium_part": "normal(8, 2)",
              "hot_job": "normal(5, 1)"
            }
          },
          "inspection": {"distribution": "uniform(1, 2)"}
        }
      ]
    },
    "process_plans": {
      "type": "object",
      "description": "Named routings for entity types that don't follow the default processing_rules.steps. Allows alternative process flows for different products.",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["steps"],
          "properties": {
            "steps": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1,
              "description": "Ordered workstation sequence for this routing"
            }
          },
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "plan_premium": {"steps": ["cnc_mill", "heat_treat", "assembly", "inspection"]},
          "plan_standard": {"steps": ["cnc_mill", "assembly", "inspection"]}
        }
      ]
    },
    "parallel_activities": {
      "type": "object",
      "description": "Fork-join blocks: one entity occupies multiple workstation branches concurrently and resumes its routing only when the join condition is met. The entity retains its identity throughout (this is not splitting). Service times for each branch step are taken from processing_rules just like for sequential steps.",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["after_step", "branches", "join_policy", "continue_at"],
          "properties": {
            "after_step": {
              "type": "string",
              "description": "Workstation after which the fork begins. The entity does not visit any other workstation between after_step and the branches."
            },
            "branches": {
              "type": "array",
              "minItems": 2,
              "description": "Concurrent branches; each is a sequence of workstations the entity occupies simultaneously with the other branches.",
              "items": {
                "type": "object",
                "required": ["steps"],
                "properties": {
                  "steps": {
                    "type": "array",
                    "items": {"type": "string"},
                    "minItems": 1,
                    "description": "Ordered workstation sequence within this branch"
                  },
                  "optional": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, this branch may be skipped when join_policy permits (e.g. 'any_k'). Has no effect under 'all'."
                  }
                },
                "additionalProperties": false
              }
            },
            "join_policy": {
              "enum": ["all", "any", "any_k"],
              "default": "all",
              "description": "Release condition at the join: 'all' = wait for every branch (AND-join), 'any' = release on the first branch to finish and cancel the rest, 'any_k' = release once k branches have finished."
            },
            "k": {
              "type": "integer",
              "minimum": 1,
              "description": "Required when join_policy='any_k'; must be <= number of branches."
            },
            "continue_at": {
              "type": "string",
              "description": "Workstation the entity proceeds to after the join. Must appear in the entity's routing (processing_rules.steps or its process_plan)."
            }
          },
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "paint_and_wire": {
            "after_step": "body_prep",
            "branches": [
              {"steps": ["paint_booth", "paint_dry"]},
              {"steps": ["wiring_station"]}
            ],
            "join_policy": "all",
            "continue_at": "final_assembly"
          },
          "triple_inspection": {
            "after_step": "machining",
            "branches": [
              {"steps": ["dimensional_check"]},
              {"steps": ["surface_check"]},
              {"steps": ["electrical_check"], "optional": true}
            ],
            "join_policy": "any_k",
            "k": 2,
            "continue_at": "packing"
          }
        }
      ]
    },
    "assembly_rules": {
      "type": "object",
      "description": "Rules for combining multiple entities into a single output entity at an assembly station (BOM-style). The station blocks until all required input quantities are available; with match_attribute, only matching components may be combined.",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["station", "inputs", "output_type"],
          "properties": {
            "station": {
              "type": "string",
              "description": "Workstation where the assembly takes place"
            },
            "inputs": {
              "type": "array",
              "minItems": 1,
              "description": "Required component entities and their quantities (BOM). Assembly waits until all are available.",
              "items": {
                "type": "object",
                "required": ["entity_type", "quantity"],
                "properties": {
                  "entity_type": {
                    "type": "string",
                    "description": "Component entity type (must exist in entity_types)"
                  },
                  "quantity": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Number of this component required per assembly"
                  },
                  "match_attribute": {
                    "type": "string",
                    "description": "If set, components are only matched when this attribute is equal across all inputs (e.g. 'order_id' to keep customer-specific kits together)"
                  }
                },
                "additionalProperties": false
              }
            },
            "output_type": {
              "type": "string",
              "description": "Entity type of the assembled output (must exist in entity_types; may have probability 0)"
            },
            "max_wait": {
              "type": "number",
              "minimum": 0,
              "description": "Maximum time the station waits for missing components before timing out (omit for unbounded wait)"
            },
            "on_timeout": {
              "enum": ["scrap_partial", "release_partial", "continue_waiting"],
              "default": "continue_waiting",
              "description": "Behavior when max_wait elapses without all components present"
            },
            "inherit_attributes_from": {
              "type": "string",
              "description": "Which input's attributes the output inherits (entity_type name). If omitted, output uses output_type defaults."
            }
          },
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "frame_assembly": {
            "station": "assembly",
            "inputs": [
              {"entity_type": "chassis", "quantity": 1, "match_attribute": "order_id"},
              {"entity_type": "engine", "quantity": 1, "match_attribute": "order_id"},
              {"entity_type": "wheel", "quantity": 4}
            ],
            "output_type": "vehicle",
            "max_wait": 240,
            "on_timeout": "continue_waiting",
            "inherit_attributes_from": "chassis"
          },
          "kit_pack": {
            "station": "packing",
            "inputs": [
              {"entity_type": "part_a", "quantity": 2},
              {"entity_type": "part_b", "quantity": 1}
            ],
            "output_type": "kit"
          }
        }
      ]
    },
    "quality_rules": {
      "type": "object",
      "description": "Scrap and rework rules applied at inspection or after specific steps",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["after_step"],
          "properties": {
            "after_step": {
              "type": "string",
              "description": "Workstation after which the quality check is evaluated"
            },
            "scrap_probability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0,
              "description": "Probability the entity is scrapped (removed from the line)"
            },
            "rework_probability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0,
              "description": "Probability the entity is sent back for rework"
            },
            "rework_target": {
              "type": "string",
              "description": "Workstation the entity loops back to for rework"
            },
            "max_rework_attempts": {
              "type": "integer",
              "minimum": 0,
              "default": 1,
              "description": "Max rework loops before the entity is scrapped"
            },
            "conditional_rates": {
              "type": "object",
              "description": "Per-entity-type scrap/rework probability overrides",
              "patternProperties": {
                "^[a-zA-Z][a-zA-Z0-9_]*$": {
                  "type": "object",
                  "properties": {
                    "scrap_probability": {"type": "number", "minimum": 0, "maximum": 1},
                    "rework_probability": {"type": "number", "minimum": 0, "maximum": 1}
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "post_machining_qc": {
            "after_step": "cnc_mill",
            "scrap_probability": 0.02,
            "rework_probability": 0.08,
            "rework_target": "cnc_mill",
            "max_rework_attempts": 2
          }
        }
      ]
    },
    "balking_rules": {
      "type": "object",
      "description": "Rules for entities being rejected/diverted at release (e.g. order cancellation when WIP is too high, or perishable entities rejected when wait exceeds shelf life). Less common in production than in services, but retained for time-critical or capacity-controlled lines.",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "properties": {
            "type": {
              "enum": ["queue_length", "wait_time", "probability", "wip_level"],
              "description": "Type of balking condition. 'wip_level' compares total WIP against a threshold."
            },
            "resource": {
              "type": "string",
              "description": "Workstation or buffer to check (for queue_length, wait_time, wip_level)"
            },
            "max_length": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum queue length / WIP before rejection"
            },
            "max_wait": {
              "type": "number",
              "minimum": 0,
              "description": "Maximum wait time before rejection (implemented as reneging timeout in SimPy)"
            },
            "probability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Base probability of rejection at release"
            },
            "priority_multipliers": {
              "type": "object",
              "description": "Rejection probability multipliers by entity priority (lower priority = more likely to be rejected)",
              "patternProperties": {
                "^(?:[1-9]|10)$": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 5
                }
              }
            }
          },
          "required": ["type"],
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "wip_cap": {"type": "wip_level", "resource": "wip_mill_to_assembly", "max_length": 20, "priority_multipliers": {"1": 0.0, "10": 2.0}}
        }
      ]
    },
    "reneging_rules": {
      "type": "object",
      "description": "Rules for entities abandoning queues (e.g. perishable materials, time-bound orders, or auto-expediting). SimPy native.",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "properties": {
            "abandon_time": {
              "type": "string",
              "pattern": "^(uniform|normal|gauss|exp)\\s*\\(\\s*[0-9.]+\\s*(,\\s*[0-9.]+\\s*)?\\)$",
              "description": "Time distribution after which a queued entity is scrapped or rerouted"
            },
            "on_abandon": {
              "enum": ["scrap", "reroute"],
              "default": "scrap",
              "description": "What happens when the entity abandons the queue"
            },
            "reroute_target": {
              "type": "string",
              "description": "Workstation to reroute to when on_abandon='reroute'"
            },
            "priority_multipliers": {
              "type": "object",
              "description": "Patience multipliers by priority (higher priority = more patient, longer tolerance)",
              "patternProperties": {
                "^(?:[1-9]|10)$": {
                  "type": "number",
                  "minimum": 0.1,
                  "maximum": 10
                }
              }
            }
          },
          "required": ["abandon_time"],
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "perishable_expiry": {
            "abandon_time": "normal(120, 30)",
            "on_abandon": "scrap",
            "priority_multipliers": {"1": 5.0, "5": 1.0, "10": 0.3}
          }
        }
      ]
    },
    "arrival_pattern": {
      "type": "object",
      "description": "Job release pattern (mutually exclusive with num_entities)",
      "properties": {
        "distribution": {
          "type": "string",
          "pattern": "^(uniform|normal|gauss|exp)\\s*\\(\\s*[0-9.]+\\s*(,\\s*[0-9.]+\\s*)?\\)$",
          "description": "Inter-release time distribution (exp(x) means mean=x, not rate=x)",
          "examples": ["exp(5)", "uniform(2, 8)", "normal(5, 1)"]
        }
      },
      "required": ["distribution"],
      "additionalProperties": false
    },
    "simple_routing": {
      "type": "object",
      "description": "Conditional routing based on entity attributes (e.g. by family, material, or priority)",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "properties": {
            "conditions": {
              "type": "array",
              "description": "If-then routing rules evaluated in order",
              "items": {
                "type": "object",
                "required": ["attribute", "value", "destination"],
                "properties": {
                  "attribute": {"type": "string"},
                  "operator": {
                    "enum": ["==", "!=", ">", "<", ">=", "<="],
                    "default": "=="
                  },
                  "value": {
                    "oneOf": [
                      {"type": "string"},
                      {"type": "number"},
                      {"type": "boolean"}
                    ]
                  },
                  "destination": {
                    "type": "string",
                    "description": "Workstation to route to if condition matches"
                  }
                }
              }
            },
            "default_destination": {
              "type": "string",
              "description": "Default workstation if no condition matches"
            }
          },
          "required": ["conditions"],
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "by_family": {
            "conditions": [
              {"attribute": "family", "operator": "==", "value": "B", "destination": "heat_treat"}
            ],
            "default_destination": "assembly"
          }
        }
      ]
    },
    "breakdowns": {
      "type": "object",
      "description": "Stochastic workstation failure and repair cycles (unplanned downtime). Component of OEE availability.",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["mtbf", "repair_time"],
          "properties": {
            "mtbf": {
              "type": "string",
              "pattern": "^(uniform|normal|gauss|exp)\\s*\\(\\s*[0-9.]+\\s*(,\\s*[0-9.]+\\s*)?\\)$",
              "description": "Mean time between failures"
            },
            "repair_time": {
              "type": "string",
              "pattern": "^(uniform|normal|gauss|exp)\\s*\\(\\s*[0-9.]+\\s*(,\\s*[0-9.]+\\s*)?\\)$",
              "description": "Time to repair (MTTR distribution)"
            },
            "preempt_in_progress": {
              "type": "boolean",
              "default": true,
              "description": "If true, the in-progress entity is interrupted; processing resumes after repair (else it restarts)"
            }
          },
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "cnc_mill": {"mtbf": "exp(480)", "repair_time": "normal(45, 15)", "preempt_in_progress": true}
        }
      ]
    },
    "maintenance": {
      "type": "object",
      "description": "Scheduled preventive maintenance windows (planned downtime)",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["workstation", "interval", "duration"],
          "properties": {
            "workstation": {
              "type": "string",
              "description": "Workstation taken offline for PM"
            },
            "interval": {
              "type": "number",
              "minimum": 0,
              "description": "Cycle time between PM events (deterministic)"
            },
            "duration": {
              "type": "string",
              "pattern": "^(uniform|normal|gauss|exp)\\s*\\(\\s*[0-9.]+\\s*(,\\s*[0-9.]+\\s*)?\\)$",
              "description": "PM duration distribution"
            },
            "first_offset": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "Time offset for the first PM event"
            }
          },
          "additionalProperties": false
        }
      },
      "examples": [
        {
          "weekly_pm_mill": {"workstation": "cnc_mill", "interval": 2400, "duration": "uniform(60, 90)", "first_offset": 2400}
        }
      ]
    },
    "shifts": {
      "type": "object",
      "description": "Working-hours pattern. Workstations not in any active shift are unavailable. Omit for 24/7 operation.",
      "properties": {
        "cycle_length": {
          "type": "number",
          "minimum": 0,
          "description": "Length of one shift cycle (e.g. 1440 for daily)"
        },
        "patterns": {
          "type": "object",
          "description": "Named on/off intervals within the cycle, keyed by workstation (or '*' for all)",
          "patternProperties": {
            "^([a-zA-Z][a-zA-Z0-9_]*|\\*)$": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["start", "end"],
                "properties": {
                  "start": {"type": "number", "minimum": 0},
                  "end": {"type": "number", "minimum": 0}
                }
              }
            }
          }
        }
      },
      "required": ["cycle_length", "patterns"],
      "examples": [
        {"cycle_length": 1440, "patterns": {"*": [{"start": 480, "end": 1440}]}}
      ]
    },
    "metrics": {
      "type": "object",
      "description": "Custom names for simulation KPIs",
      "properties": {
        "released_metric": {
          "type": "string",
          "default": "entities_released",
          "examples": ["parts_released", "orders_started"]
        },
        "completed_metric": {
          "type": "string",
          "default": "entities_completed",
          "examples": ["parts_produced", "orders_shipped", "units_finished"]
        },
        "scrap_metric": {
          "type": "string",
          "default": "entities_scrapped",
          "examples": ["parts_scrapped", "units_rejected"]
        },
        "rework_metric": {
          "type": "string",
          "default": "entities_reworked",
          "examples": ["parts_reworked"]
        },
        "balk_metric": {
          "type": "string",
          "default": "entities_rejected",
          "examples": ["orders_cancelled"]
        },
        "reneged_metric": {
          "type": "string",
          "default": "entities_expired",
          "examples": ["batches_aborted"]
        },
        "value_metric": {
          "type": "string",
          "default": "total_value",
          "examples": ["total_revenue", "total_cost", "throughput_value"]
        }
      },
      "additionalProperties": false
    },
    "statistics": {
      "type": "object",
      "description": "Statistics collection. Each metric is an object with 'enabled', optional breakdown dimensions (per_station, per_entity_type), and optional distribution detail (percentiles, histogram, time_buckets). For backwards compatibility, a boolean may still be passed in place of the object (e.g. 'collect_wait_times': true is equivalent to 'wait_times': {'enabled': true}).",
      "properties": {
        "warmup_period": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "Time to exclude from statistics (steady-state analysis)"
        },
        "wait_times": {
          "oneOf": [
            {"type": "boolean"},
            {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": true},
                "per_station": {"type": "boolean", "default": false, "description": "Report wait times broken down by workstation"},
                "per_entity_type": {"type": "boolean", "default": false, "description": "Report wait times broken down by entity type"},
                "percentiles": {
                  "type": "array",
                  "items": {"type": "number", "minimum": 0, "maximum": 100},
                  "default": [50, 95],
                  "description": "Percentiles to report in addition to mean and max"
                },
                "histogram": {
                  "type": "object",
                  "properties": {
                    "enabled": {"type": "boolean", "default": false},
                    "bins": {"type": "integer", "minimum": 1, "default": 20}
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "queue_lengths": {
          "oneOf": [
            {"type": "boolean"},
            {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": true},
                "per_station": {"type": "boolean", "default": true},
                "report": {
                  "type": "array",
                  "items": {"enum": ["avg", "max", "time_series"]},
                  "default": ["avg", "max"],
                  "description": "Which queue-length statistics to emit"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "cycle_time": {
          "oneOf": [
            {"type": "boolean"},
            {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": true},
                "per_entity_type": {"type": "boolean", "default": false, "description": "Report cycle time broken down by entity type"},
                "percentiles": {
                  "type": "array",
                  "items": {"type": "number", "minimum": 0, "maximum": 100},
                  "default": [50, 95]
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "throughput": {
          "oneOf": [
            {"type": "boolean"},
            {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": true},
                "per_entity_type": {"type": "boolean", "default": false, "description": "Report throughput counts broken down by entity type"},
                "time_buckets": {
                  "type": "number",
                  "minimum": 0,
                  "description": "If set, also report throughput per time bucket of this length (e.g. 60 for hourly)"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "utilization": {
          "oneOf": [
            {"type": "boolean"},
            {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": true},
                "per_station": {"type": "boolean", "default": true},
                "decompose": {"type": "boolean", "default": false, "description": "Split utilization into busy / setup / repair / blocked / starved"}
              },
              "additionalProperties": false
            }
          ]
        },
        "wip": {
          "oneOf": [
            {"type": "boolean"},
            {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": true},
                "per_station": {"type": "boolean", "default": false, "description": "Report WIP per workstation as well as system-level"},
                "report": {
                  "type": "array",
                  "items": {"enum": ["avg", "max", "time_series"]},
                  "default": ["avg", "max"]
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "oee": {
          "oneOf": [
            {"type": "boolean"},
            {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": false, "description": "Compute OEE = Availability x Performance x Quality per workstation"},
                "per_station": {"type": "boolean", "default": true}
              },
              "additionalProperties": false
            }
          ]
        },
        "events": {
          "type": "object",
          "description": "Time-stamped event logs for post-hoc analysis of discrete occurrences (balks, reneges, breakdowns). Useful when the distribution over time matters, not just the total count.",
          "properties": {
            "log_balks": {"type": "boolean", "default": false},
            "log_reneges": {"type": "boolean", "default": false},
            "log_breakdowns": {"type": "boolean", "default": false},
            "log_scrap": {"type": "boolean", "default": false},
            "log_rework": {"type": "boolean", "default": false},
            "time_buckets": {
              "type": "number",
              "minimum": 0,
              "description": "If set, also aggregate event counts into buckets of this length"
            }
          },
          "additionalProperties": false
        },
        "collect_wait_times": {"type": "boolean", "deprecated": true, "description": "Deprecated alias for wait_times.enabled (no breakdown). Kept for backwards compatibility."},
        "collect_queue_lengths": {"type": "boolean", "deprecated": true, "description": "Deprecated alias for queue_lengths.enabled."},
        "collect_utilization": {"type": "boolean", "deprecated": true, "description": "Deprecated alias for utilization.enabled."},
        "collect_cycle_time": {"type": "boolean", "deprecated": true, "description": "Deprecated alias for cycle_time.enabled."},
        "collect_wip": {"type": "boolean", "deprecated": true, "description": "Deprecated alias for wip.enabled."},
        "collect_oee": {"type": "boolean", "deprecated": true, "description": "Deprecated alias for oee.enabled."}
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "title": "Two-Stage Machining Line",
      "description": "CNC mill feeding assembly through a finite WIP buffer, with breakdowns and post-machining QC",
      "run_time": 2400,
      "time_unit": "minutes",
      "arrival_pattern": {"distribution": "exp(6)"},
      "entity_types": {
        "standard_part": {"probability": 0.7, "value": {"min": 50, "max": 80}, "priority": 5, "batch_size": 5, "attributes": {"family": "A"}},
        "premium_part": {"probability": 0.25, "value": {"min": 150, "max": 250}, "priority": 3, "batch_size": 5, "attributes": {"family": "B"}},
        "hot_job": {"probability": 0.05, "value": {"min": 500, "max": 1000}, "priority": 1, "batch_size": 1, "attributes": {"family": "B"}}
      },
      "workstations": {
        "cnc_mill": {"capacity": 2, "resource_type": "priority", "setup_time": "normal(15, 3)", "changeover_matrix": {"A>B": "uniform(20, 30)", "B>A": "uniform(20, 30)"}},
        "assembly": {"capacity": 3, "resource_type": "preemptive"},
        "inspection": {"capacity": 1, "resource_type": "fifo"}
      },
      "buffers": {
        "wip_mill_to_assembly": {"capacity": 15, "upstream": "cnc_mill", "downstream": "assembly"}
      },
      "processing_rules": {
        "steps": ["cnc_mill", "assembly", "inspection"],
        "cnc_mill": {"distribution": "normal(8, 1.5)", "scale_by_batch": true},
        "assembly": {
          "conditional_distributions": {
            "standard_part": "normal(5, 1)",
            "premium_part": "normal(8, 2)",
            "hot_job": "normal(5, 1)"
          },
          "scale_by_batch": true
        },
        "inspection": {"distribution": "uniform(1, 2)", "scale_by_batch": false}
      },
      "quality_rules": {
        "post_machining_qc": {
          "after_step": "cnc_mill",
          "scrap_probability": 0.02,
          "rework_probability": 0.08,
          "rework_target": "cnc_mill",
          "max_rework_attempts": 2
        }
      },
      "breakdowns": {
        "cnc_mill": {"mtbf": "exp(480)", "repair_time": "normal(45, 15)", "preempt_in_progress": true}
      },
      "maintenance": {
        "weekly_pm_mill": {"workstation": "cnc_mill", "interval": 2400, "duration": "uniform(60, 90)", "first_offset": 2400}
      },
      "metrics": {
        "released_metric": "parts_released",
        "completed_metric": "parts_produced",
        "scrap_metric": "parts_scrapped",
        "rework_metric": "parts_reworked",
        "value_metric": "total_revenue"
      },
      "statistics": {
        "warmup_period": 240,
        "wait_times": {"enabled": true, "per_station": true, "percentiles": [50, 95]},
        "queue_lengths": {"enabled": true, "per_station": true, "report": ["avg", "max"]},
        "utilization": {"enabled": true, "per_station": true, "decompose": true},
        "cycle_time": {"enabled": true, "per_entity_type": true},
        "wip": {"enabled": true, "per_station": true},
        "oee": {"enabled": true, "per_station": true}
      }
    },
    {
      "title": "PCB Assembly with Parallel Sub-Assembly",
      "description": "Electronics line where each order forks into SMD placement, soldering, and firmware flashing, rejoins, then proceeds to QC. Demonstrates parallel_activities with per-station and per-entity-type statistics.",
      "run_time": 480,
      "time_unit": "minutes",
      "arrival_pattern": {"distribution": "uniform(6, 12)"},
      "entity_types": {
        "standard_order": {"probability": 0.75, "value": {"min": 80, "max": 80}, "priority": 5},
        "rush_order": {"probability": 0.25, "value": {"min": 200, "max": 200}, "priority": 1}
      },
      "workstations": {
        "kitting": {"capacity": 1, "resource_type": "fifo"},
        "smd": {"capacity": 2, "resource_type": "priority"},
        "soldering": {"capacity": 1, "resource_type": "priority"},
        "firmware": {"capacity": 1, "resource_type": "fifo"},
        "qc_packaging": {"capacity": 1, "resource_type": "priority"}
      },
      "processing_rules": {
        "steps": ["kitting", "smd", "soldering", "firmware", "qc_packaging"],
        "kitting": {"distribution": "uniform(4, 7)", "scale_by_batch": false},
        "smd": {
          "conditional_distributions": {
            "standard_order": "normal(10, 2)",
            "rush_order": "normal(7, 1.5)"
          },
          "scale_by_batch": false
        },
        "soldering": {
          "conditional_distributions": {
            "standard_order": "uniform(8, 14)",
            "rush_order": "uniform(5, 9)"
          },
          "scale_by_batch": false
        },
        "firmware": {"distribution": "uniform(3, 6)", "scale_by_batch": false},
        "qc_packaging": {"distribution": "normal(6, 1)", "scale_by_batch": false}
      },
      "parallel_activities": {
        "pcb_sub_assembly": {
          "after_step": "kitting",
          "branches": [
            {"steps": ["smd"]},
            {"steps": ["soldering"]},
            {"steps": ["firmware"]}
          ],
          "join_policy": "all",
          "continue_at": "qc_packaging"
        }
      },
      "balking_rules": {
        "kitting_overflow": {
          "type": "queue_length",
          "resource": "kitting",
          "max_length": 8
        }
      },
      "breakdowns": {
        "smd": {"mtbf": "exp(150)", "repair_time": "uniform(10, 25)", "preempt_in_progress": true}
      },
      "metrics": {
        "released_metric": "orders_received",
        "completed_metric": "orders_completed",
        "balk_metric": "orders_balked",
        "value_metric": "total_revenue"
      },
      "statistics": {
        "warmup_period": 30,
        "wait_times": {"enabled": true, "per_station": true, "per_entity_type": true, "percentiles": [50, 95], "histogram": {"enabled": true, "bins": 20}},
        "queue_lengths": {"enabled": true, "per_station": true, "report": ["avg", "max"]},
        "cycle_time": {"enabled": true, "per_entity_type": true, "percentiles": [50, 95]},
        "throughput": {"enabled": true, "per_entity_type": true, "time_buckets": 60},
        "utilization": {"enabled": true, "per_station": true, "decompose": true},
        "events": {"log_balks": true, "log_breakdowns": true, "time_buckets": 60}
      }
    },
    {
      "title": "Mixed-Routing Job Shop with Batch Oven",
      "description": "Two routings: premium parts pass through a batch heat-treat oven, standard parts skip it. Shift schedule applied to all workstations.",
      "run_time": 4800,
      "time_unit": "minutes",
      "arrival_pattern": {"distribution": "exp(8)"},
      "entity_types": {
        "standard_part": {"probability": 0.6, "value": {"min": 40, "max": 70}, "priority": 5, "process_plan": "plan_standard", "attributes": {"family": "A"}},
        "premium_part": {"probability": 0.4, "value": {"min": 120, "max": 200}, "priority": 3, "process_plan": "plan_premium", "attributes": {"family": "B"}}
      },
      "workstations": {
        "cnc_mill": {"capacity": 2, "resource_type": "fifo", "setup_time": "normal(15, 3)"},
        "heat_treat": {"capacity": 1, "resource_type": "fifo", "batch_processing": {"min_batch": 4, "max_batch": 8, "wait_for_full": false}},
        "assembly": {"capacity": 3, "resource_type": "fifo"},
        "inspection": {"capacity": 1, "resource_type": "fifo"}
      },
      "process_plans": {
        "plan_premium": {"steps": ["cnc_mill", "heat_treat", "assembly", "inspection"]},
        "plan_standard": {"steps": ["cnc_mill", "assembly", "inspection"]}
      },
      "processing_rules": {
        "steps": ["cnc_mill", "assembly", "inspection"],
        "cnc_mill": {"distribution": "normal(10, 2)"},
        "heat_treat": {"distribution": "uniform(60, 90)", "scale_by_batch": false},
        "assembly": {"distribution": "normal(7, 1.5)"},
        "inspection": {"distribution": "uniform(2, 4)"}
      },
      "quality_rules": {
        "final_qc": {
          "after_step": "inspection",
          "conditional_rates": {
            "standard_part": {"scrap_probability": 0.015, "rework_probability": 0.04},
            "premium_part": {"scrap_probability": 0.005, "rework_probability": 0.08}
          },
          "rework_target": "assembly",
          "max_rework_attempts": 2
        }
      },
      "breakdowns": {
        "heat_treat": {"mtbf": "exp(1200)", "repair_time": "uniform(60, 180)"}
      },
      "shifts": {
        "cycle_length": 1440,
        "patterns": {"*": [{"start": 480, "end": 1440}]}
      },
      "metrics": {
        "released_metric": "entities_released",
        "completed_metric": "entities_shipped",
        "scrap_metric": "entities_scrapped",
        "value_metric": "contribution_margin"
      },
      "statistics": {
        "warmup_period": 480,
        "cycle_time": {"enabled": true, "per_entity_type": true},
        "throughput": {"enabled": true, "per_entity_type": true},
        "wip": {"enabled": true, "per_station": true},
        "utilization": {"enabled": true, "per_station": true, "decompose": true},
        "oee": {"enabled": true, "per_station": true}
      }
    }
  ],
  "additionalProperties": false
}